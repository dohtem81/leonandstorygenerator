---
interface Props {
  title: string;
  lang?: string;
  chapterHref?: string; // current chapter path for lang switching
}

const { title, lang = 'pl', chapterHref } = Astro.props;
const otherLang = lang === 'pl' ? 'en' : 'pl';
const langLabel = lang === 'pl' ? 'EN' : 'PL';
const otherHref = chapterHref
  ? `/${otherLang}/${chapterHref}`
  : `/${otherLang}`;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Bajkogenerator</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <script data-goatcounter="https://leonandstorygenerator.goatcounter.com/count"
            async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="nebula" aria-hidden="true"></div>

    <header>
      <a href="/" class="logo">✨ Bajkogenerator</a>
      <a href={otherHref} class="lang-switch" title="Switch language">{langLabel}</a>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>
        {lang === 'pl'
          ? 'Gdzieś pomiędzy snem a rzeczywistością…'
          : 'Somewhere between dream and reality…'}
      </p>
      <p class="visitor-counter">
        <span class="gc-count" data-path="/">—</span>
        {lang === 'pl' ? ' czytelników odwiedziło tę stronę' : ' readers have visited this site'}
      </p>
    </footer>

    <script>
      const canvas = document.getElementById('stars') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        draw();
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (let i = 0; i < 240; i++) {
          const x = Math.random() * canvas.width;
          const y = Math.random() * canvas.height;
          const r = Math.random() * 1.3 + 0.2;
          const opacity = Math.random() * 0.65 + 0.15;
          ctx.beginPath();
          ctx.arc(x, y, r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
          ctx.fill();
        }
      }

      resize();
      window.addEventListener('resize', resize);
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    background: #080818;
    color: #e8dcc8;
    font-family: 'Lora', Georgia, serif;
    display: flex;
    flex-direction: column;
  }

  #stars {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .nebula {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 15% 25%, rgba(90, 20, 140, 0.28) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 60%, rgba(20, 55, 130, 0.22) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 90%, rgba(70, 10, 90, 0.18) 0%, transparent 45%);
  }

  header {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid rgba(240, 192, 96, 0.12);
    backdrop-filter: blur(4px);
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    color: #f0c060;
    text-decoration: none;
    text-shadow: 0 0 20px rgba(240, 192, 96, 0.5);
    letter-spacing: 0.02em;
    transition: text-shadow 0.3s;
  }
  .logo:hover {
    text-shadow: 0 0 32px rgba(240, 192, 96, 0.85);
  }

  .lang-switch {
    font-family: 'Lora', serif;
    font-size: 0.85rem;
    color: #9090b8;
    text-decoration: none;
    border: 1px solid rgba(144, 144, 184, 0.35);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    letter-spacing: 0.1em;
    transition: color 0.25s, border-color 0.25s;
  }
  .lang-switch:hover {
    color: #f0c060;
    border-color: rgba(240, 192, 96, 0.5);
  }

  main {
    position: relative;
    z-index: 5;
    flex: 1;
    padding: 2.5rem 1rem;
  }

  footer {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: 1.5rem;
    font-size: 0.78rem;
    font-style: italic;
    color: #4a4a6a;
    border-top: 1px solid rgba(240, 192, 96, 0.07);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .visitor-counter {
    font-size: 0.72rem;
    color: #3a3a55;
  }

  .gc-count {
    color: #6060a0;
    font-style: normal;
  }

  a { color: inherit; }

  @media (max-width: 640px) {
    header { padding: 1rem 1.25rem; }
  }
</style>
