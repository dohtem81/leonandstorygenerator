---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

export function getStaticPaths() {
  const paths = [];
  for (const lang of ['pl', 'en']) {
    for (let i = 1; i <= 28; i++) {
      paths.push({ params: { lang, chapter: String(i) } });
    }
  }
  return paths;
}

const { lang, chapter } = Astro.params as { lang: string; chapter: string };
const i = parseInt(chapter);
const num = String(i).padStart(3, '0');
const totalChapters = 28;

const storiesDir = path.join(process.cwd(), '..', 'stories', lang);

// Parse chapter titles
const chaptersRaw = fs.readFileSync(path.join(storiesDir, 'chapters.txt'), 'utf-8');
const chapterLines = chaptersRaw
  .split('\n')
  .filter(line => /^(Rozdział|Chapter)\s+\d+/.test(line.trim()));

const chapterTitle = chapterLines[i - 1]?.split('—')[1]?.trim() ?? '';

// Read story content
const content = fs.readFileSync(path.join(storiesDir, `${num}.txt`), 'utf-8');

// Split on blank lines; preserve inner line breaks as <br>
const paragraphs = content
  .split(/\n{2,}/)
  .map(p => p.trim())
  .filter(Boolean);

const isPolish = lang === 'pl';
const prevNum  = i > 1 ? i - 1 : null;
const nextNum  = i < totalChapters ? i + 1 : null;

const chapterLabel = isPolish ? 'Rozdział' : 'Chapter';
const backLabel    = isPolish ? '← Spis rozdziałów' : '← Table of Contents';
const prevLabel    = isPolish ? '← Poprzedni' : '← Previous';
const nextLabel    = isPolish ? 'Następny →' : 'Next →';
---

<Layout
  title={`${chapterLabel} ${i} — ${chapterTitle}`}
  lang={lang}
  chapterHref={chapter}
>
  <article class="container">

    <nav class="breadcrumb">
      <a href={`/${lang}`}>{backLabel}</a>
    </nav>

    <header class="story-header">
      <span class="chapter-label">{chapterLabel} {String(i).padStart(2, '0')}</span>
      <h1 class="story-title">{chapterTitle}</h1>
    </header>

    <div class="parchment">
      {paragraphs.map((p, idx) => (
        <p class={idx === 0 ? 'first-para' : ''} set:html={p.replace(/\n/g, '<br>')} />
      ))}
    </div>

    <nav class="chapter-nav">
      {prevNum ? (
        <a href={`/${lang}/${prevNum}`} class="nav-btn nav-prev">
          <span class="nav-arrow">←</span>
          <span class="nav-text">
            <span class="nav-label">{prevLabel.replace(' ←', '')}</span>
            <span class="nav-title">{chapterLines[prevNum - 1]?.split('—')[1]?.trim()}</span>
          </span>
        </a>
      ) : <div />}

      {nextNum ? (
        <a href={`/${lang}/${nextNum}`} class="nav-btn nav-next">
          <span class="nav-text nav-text-right">
            <span class="nav-label">{nextLabel.replace('→ ', '')}</span>
            <span class="nav-title">{chapterLines[nextNum - 1]?.split('—')[1]?.trim()}</span>
          </span>
          <span class="nav-arrow">→</span>
        </a>
      ) : <div />}
    </nav>

  </article>
</Layout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  /* breadcrumb */
  .breadcrumb {
    margin-bottom: 2rem;
  }
  .breadcrumb a {
    font-size: 0.85rem;
    color: #7878a0;
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: #f0c060; }

  /* story header */
  .story-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .chapter-label {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: #7878a0;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .story-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 5vw, 2.8rem);
    color: #f0c060;
    text-shadow:
      0 0 28px rgba(240, 192, 96, 0.45),
      0 0 60px rgba(240, 192, 96, 0.18);
    line-height: 1.2;
  }

  /* parchment panel */
  .parchment {
    background: #f5eed8;
    border-radius: 16px;
    padding: 2.5rem 3rem;
    box-shadow:
      0 0 0 1px rgba(180, 150, 80, 0.3),
      0 8px 40px rgba(0, 0, 0, 0.45),
      0 0 80px rgba(240, 192, 96, 0.07);
    color: #2a1f0f;
    font-family: 'Lora', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .parchment p {
    margin-bottom: 1.2em;
  }
  .parchment p:last-child {
    margin-bottom: 0;
  }

  /* drop cap on first paragraph */
  .parchment .first-para::first-letter {
    font-family: 'Playfair Display', serif;
    font-size: 3.6em;
    font-weight: 700;
    color: #8b5e1a;
    float: left;
    line-height: 0.78;
    margin-right: 0.08em;
    margin-top: 0.1em;
  }

  /* navigation */
  .chapter-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(240, 192, 96, 0.15);
    border-radius: 12px;
    text-decoration: none;
    color: #c0b8a0;
    max-width: 48%;
    transition: background 0.25s, border-color 0.25s, color 0.25s, transform 0.2s;
    backdrop-filter: blur(6px);
  }

  .nav-btn:hover {
    background: rgba(240, 192, 96, 0.07);
    border-color: rgba(240, 192, 96, 0.4);
    color: #f0ead8;
    transform: translateY(-2px);
  }

  .nav-next { margin-left: auto; }

  .nav-arrow {
    font-size: 1.2rem;
    color: #f0c060;
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .nav-btn:hover .nav-arrow { opacity: 1; }

  .nav-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .nav-text-right { text-align: right; }

  .nav-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7878a0;
  }
  .nav-title {
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .parchment { padding: 1.6rem 1.4rem; font-size: 0.98rem; }
    .nav-btn   { max-width: 100%; width: 100%; }
    .chapter-nav { flex-direction: column; }
  }
</style>
